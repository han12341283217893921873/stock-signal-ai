{
      "version": 2,
      "functions": {
              "api/index.ts": {
                        "includeFiles": "{server/**,drizzle/**,shared/**}"
              }
      },
      "rewrites": [
              {
                        "source": "/api/(.*)",
                        "destination": "/api/index.ts"
              },
              {
                        "source": "/trpc/(.*)",
                        "destination": "/api/index.ts"
              },
              {
                        "source": "/((?!api|trpc).*)",
                        "destination": "/index.html"
              }
      ]
}
